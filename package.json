{
  "name": "gamification-anti-doping",
  "private": true,
  "version": "1.0.0",
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace client\" \"npm run dev --workspace server\"",
    "build": "npm run build --workspace client && npm run build --workspace server",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "prisma:generate": "npm run prisma:generate --workspace server",
    "prisma:seed": "npm run prisma:seed --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
